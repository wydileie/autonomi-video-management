# Internet-facing demo configuration using the self-contained local Autonomi
# devnet. Copy to .env.local-public, replace every secret/domain value, then run
# with docker-compose.local.yml and docker-compose.local-public.yml.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-long-random-postgres-root-password

ADMIN_DB=admindb
ADMIN_USER=admin
ADMIN_PASS=replace-with-long-random-admin-db-password

# Keep production auth validation enabled even though storage is the local
# devnet. The app will refuse weak/default admin credentials in this mode.
APP_ENV=production
ADMIN_USERNAME=autvid-demo-admin
ADMIN_PASSWORD=replace-with-long-random-admin-password
ADMIN_AUTH_SECRET=replace-with-long-random-token-signing-secret-at-least-32-chars
ADMIN_AUTH_TTL_HOURS=12

# Use an absolute host path on the server. This holds originals and transcoded
# HLS segments while jobs are processing or awaiting approval.
VIDEO_PROCESSING_HOST_PATH=/srv/autonomi-video-management/processing

DOMAIN=demo.example.com
APP_HTTP_PORT=80
CORS_ALLOWED_ORIGINS=https://demo.example.com,http://demo.example.com

ANTD_PAYMENT_MODE=auto
ANTD_METADATA_PAYMENT_MODE=merkle
ANTD_UPLOAD_VERIFY=true
ANTD_UPLOAD_RETRIES=3
ANTD_UPLOAD_TIMEOUT_SECONDS=120
ANTD_QUOTE_CONCURRENCY=8
ANTD_UPLOAD_CONCURRENCY=4
ANTD_APPROVE_ON_STARTUP=false

UPLOAD_MAX_FILE_BYTES=21474836480
UPLOAD_MAX_DURATION_SECONDS=14400
UPLOAD_MAX_SOURCE_PIXELS=33177600
UPLOAD_MAX_SOURCE_LONG_EDGE=7680
UPLOAD_MIN_FREE_BYTES=536870912
UPLOAD_MAX_CONCURRENT_SAVES=2
UPLOAD_FFPROBE_TIMEOUT_SECONDS=30
HLS_SEGMENT_DURATION=0.75
FFMPEG_THREADS=2
FFMPEG_FILTER_THREADS=1
FINAL_QUOTE_APPROVAL_TTL_SECONDS=14400
APPROVAL_CLEANUP_INTERVAL_SECONDS=300

ANT_DEVNET_PRESET=default
# true gives a clean devnet on each start. Set false only when you intentionally
# want to try preserving local-devnet data across restarts for a short demo.
ANT_DEVNET_RESET_ON_START=true
ANTD_LOG_LEVEL=warn
ANTD_QUOTE_TIMEOUT_SECS=60
ANTD_STORE_TIMEOUT_SECS=120

CATALOG_ADDRESS=

STREAM_CATALOG_CACHE_TTL_SECONDS=10
STREAM_MANIFEST_CACHE_TTL_SECONDS=300
STREAM_SEGMENT_CACHE_TTL_SECONDS=60
STREAM_SEGMENT_CACHE_MAX_BYTES=67108864
