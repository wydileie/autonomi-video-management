{
  "name": "Home Development",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "customizations": {
    "claude": {
      "mcpServers": {
        "fetch": {
          "command": "/usr/local/bin/uvx",
          "args": [
            "--native-tls",
            "mcp-server-fetch"
          ]
        },
        "git-repo-research": {
          "command": "/usr/local/bin/uvx",
          "args": [
            "--native-tls",
            "awslabs.git-repo-research-mcp-server@latest"
          ],
          "env": {
            "AWS_REGION": "us-east-2",
            "FASTMCP_LOG_LEVEL": "ERROR"
          }
        },
        "filesystem": {
          "command": "npx",
          "args": [
            "-y",
            "@modelcontextprotocol/server-filesystem",
            "${containerWorkspaceFolder}"
          ]
        },
        "git": {
          "command": "/usr/local/bin/uvx",
          "args": [
            "--native-tls",
            "mcp-server-git",
            "--repository",
            "${containerWorkspaceFolder}"
          ]
        },
        "github": {
          "command": "/usr/local/bin/uvx",
          "args": [
            "--native-tls",
            "mcp-server-github"
          ],
          "env": {
            "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
          }
        },
        "postgres": {
          "command": "/usr/local/bin/uvx",
          "args": [
            "--native-tls",
            "mcp-server-postgres",
            "${env:DATABASE_URL}"
          ]
        },
        "docker": {
          "command": "/usr/local/bin/uvx",
          "args": [
            "--native-tls",
            "mcp-server-docker"
          ]
        },
        "memory": {
          "command": "/usr/local/bin/uvx",
          "args": [
            "--native-tls",
            "mcp-server-memory"
          ]
        },
        "sequential-thinking": {
          "command": "npx",
          "args": [
            "-y",
            "@modelcontextprotocol/server-sequential-thinking"
          ]
        },
        "kubernetes": {
          "command": "/usr/local/bin/uvx",
          "args": [
            "--native-tls",
            "mcp-server-kubernetes"
          ]
        },
        "brave-search": {
          "command": "npx",
          "args": [
            "-y",
            "@brave/brave-search-mcp-server"
          ],
          "env": {
            "BRAVE_API_KEY": "${env:BRAVE_API_KEY}"
          }
        },
        "antd-autonomi": {
          "command": "antd-mcp",
          "env": {
            "ANTD_BASE_URL": "http://127.0.0.1:8082",
            "ALL_PROXY": "",
            "all_proxy": "",
            "HTTP_PROXY": "",
            "http_proxy": "",
            "HTTPS_PROXY": "",
            "https_proxy": "",
            "NO_PROXY": "localhost,127.0.0.1",
            "no_proxy": "localhost,127.0.0.1"
          }
        }
      }
    },
    "codex": {
      "mcpServers": {
        "github": {
          "url": "https://api.githubcopilot.com/mcp/",
          "bearer_token_env_var": "GITHUB_TOKEN"
        },
        "git-repo-research": {
          "enabled": false
        },
        "context7": {
          "url": "https://mcp.context7.com/mcp"
        },
        "memory": {
          "command": "npx",
          "args": [
            "-y",
            "@modelcontextprotocol/server-memory"
          ]
        },
        "postgres": {
          "command": "/bin/bash",
          "args": [
            "-lc",
            "exec npx -y @modelcontextprotocol/server-postgres \"${DATABASE_URL:-postgresql://postgres:RootPassword@127.0.0.1:5432/postgres}\""
          ]
        },
        "antd-autonomi": {
          "command": "antd-mcp",
          "env": {
            "ANTD_BASE_URL": "http://127.0.0.1:8082",
            "ALL_PROXY": "",
            "all_proxy": "",
            "HTTP_PROXY": "",
            "http_proxy": "",
            "HTTPS_PROXY": "",
            "https_proxy": "",
            "NO_PROXY": "localhost,127.0.0.1",
            "no_proxy": "localhost,127.0.0.1"
          }
        }
      }
    },
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "github.vscode-pull-request-github",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "mechatroner.rainbow-csv",
        "redhat.vscode-xml",
        "redhat.vscode-yaml",
        "ms-vscode.powershell",
        "tamasfe.even-better-toml",
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "anthropic.claude-code",
        "openai.chatgpt",
        "github.vscode-github-actions"
      ]
    },
    "settings": {
      "mcp": {
        "servers": {
          "fetch": {
            "type": "stdio",
            "command": "/usr/local/bin/uvx",
            "args": ["--native-tls", "mcp-server-fetch"]
          },
          "filesystem": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-filesystem", "${containerWorkspaceFolder}"]
          },
          "git": {
            "type": "stdio",
            "command": "/usr/local/bin/uvx",
            "args": ["--native-tls", "mcp-server-git", "--repository", "${containerWorkspaceFolder}"]
          },
          "github": {
            "url": "https://api.githubcopilot.com/mcp/"
          },
          "postgres": {
            "type": "stdio",
            "command": "/bin/bash",
            "args": [
              "-lc",
              "exec npx -y @modelcontextprotocol/server-postgres \"${DATABASE_URL:-postgresql://postgres:RootPassword@127.0.0.1:5432/postgres}\""
            ]
          },
          "docker": {
            "type": "stdio",
            "command": "/usr/local/bin/uvx",
            "args": ["--native-tls", "mcp-server-docker"]
          },
          "memory": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-memory"]
          },
          "sequential-thinking": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
          },
          "kubernetes": {
            "type": "stdio",
            "command": "/usr/local/bin/uvx",
            "args": ["--native-tls", "mcp-server-kubernetes"]
          },
          "brave-search": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@brave/brave-search-mcp-server"],
            "env": {
              "BRAVE_API_KEY": "${env:BRAVE_API_KEY}"
            }
          },
          "context7": {
            "url": "https://mcp.context7.com/mcp"
          },
          "antd-autonomi": {
            "type": "stdio",
            "command": "antd-mcp",
            "env": {
              "ANTD_BASE_URL": "http://127.0.0.1:8082",
              "ALL_PROXY": "",
              "all_proxy": "",
              "HTTP_PROXY": "",
              "http_proxy": "",
              "HTTPS_PROXY": "",
              "https_proxy": "",
              "NO_PROXY": "localhost,127.0.0.1",
              "no_proxy": "localhost,127.0.0.1"
            }
          }
        }
      }
    }
  },
  "forwardPorts": [80, 3000, 5000, 5432, 8000, 8080, 8081, 8082, 50051],
  "postCreateCommand": "python3 .devcontainer/setup_claude.py",
  "postStartCommand": "bash .devcontainer/post_start.sh",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=${localEnv:HOME}/.devcontainer_bash_history,target=/home/vscode/.bash_history,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.codex_vscode,target=/home/vscode/.codex,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/gh,target=/home/vscode/.config/gh,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "BRAVE_API_KEY": "${localEnv:BRAVE_API_KEY}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
  },
  "remoteEnv": {
    "HISTFILE": "/home/vscode/.bash_history",
    "PROMPT_COMMAND": "history -a",
    "BRAVE_API_KEY": "${localEnv:BRAVE_API_KEY}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "ANTD_NETWORK": "local",
    "AUTONOMI_WALLET_KEY": "${localEnv:AUTONOMI_WALLET_KEY}"
  },
  "remoteUser": "vscode"
}
