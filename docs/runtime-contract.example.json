{
  "schema_version": "2.0",
  "runtime_mode": "standalone-launcher-example",
  "description": "Example host contract for running the backend services outside Docker while preserving the Compose API and app-data boundaries.",
  "public_http": {
    "app_origin": "http://127.0.0.1:8080",
    "admin_api_base": "http://127.0.0.1:8080/api",
    "stream_api_base": "http://127.0.0.1:8080/stream",
    "route_contract": [
      {
        "public_path": "/api/*",
        "target": "rust_admin",
        "target_base_url": "http://127.0.0.1:8000",
        "strip_prefix": "/api"
      },
      {
        "public_path": "/stream/*",
        "target": "rust_stream",
        "target_base_url": "http://127.0.0.1:8081",
        "strip_prefix": null
      }
    ]
  },
  "services": {
    "rust_admin": {
      "role": "Upload, FFmpeg transcoding, admin auth, SQLite job state, Autonomi writes, catalog publication, and delete.",
      "bind_url": "http://127.0.0.1:8000",
      "required_environment": {
        "AUTVID_DATA_DIR": "/Users/example/Library/Application Support/Autonomi Video Management",
        "ADMIN_DB_PATH": "/Users/example/Library/Application Support/Autonomi Video Management/autvid.sqlite3",
        "UPLOAD_TEMP_DIR": "/Users/example/Library/Application Support/Autonomi Video Management/processing",
        "CATALOG_STATE_PATH": "/Users/example/Library/Application Support/Autonomi Video Management/catalog/catalog.json",
        "PUBLISHED_CATALOG_ADDRESS": "",
        "ALL_CATALOG_ADDRESS": "",
        "ANTD_URL": "http://127.0.0.1:8082",
        "CORS_ALLOWED_ORIGINS": "http://127.0.0.1:8080"
      }
    },
    "rust_stream": {
      "role": "HLS playlist generation and Autonomi segment proxy for playback.",
      "bind_url": "http://127.0.0.1:8081",
      "required_environment": {
        "ANTD_URL": "http://127.0.0.1:8082",
        "CATALOG_STATE_PATH": "/Users/example/Library/Application Support/Autonomi Video Management/catalog/catalog.json",
        "PUBLISHED_CATALOG_ADDRESS": "",
        "CORS_ALLOWED_ORIGINS": "http://127.0.0.1:8080"
      }
    },
    "antd": {
      "role": "Autonomi gateway daemon for storage, retrieval, wallet, and payment operations.",
      "rest_url": "http://127.0.0.1:8082"
    },
    "sqlite": {
      "role": "Embedded admin metadata, auth sessions, durable jobs, and local recovery log.",
      "path": "/Users/example/Library/Application Support/Autonomi Video Management/autvid.sqlite3"
    }
  },
  "storage_paths": {
    "app_data": {
      "path": "/Users/example/Library/Application Support/Autonomi Video Management",
      "durability": "persistent",
      "contains": ["autvid.sqlite3", "catalog/catalog.json", "processing/"]
    }
  },
  "health_checks": [
    "http://127.0.0.1:8082/livez",
    "http://127.0.0.1:8000/livez",
    "http://127.0.0.1:8081/livez",
    "http://127.0.0.1:8000/health",
    "http://127.0.0.1:8081/health"
  ],
  "compose_equivalent": {
    "app_data_mount": "${AUTVID_DATA_HOST_PATH:-./.autvid/app_data}:/var/lib/autvid",
    "sqlite_path": "/var/lib/autvid/autvid.sqlite3",
    "catalog_state_path": "/var/lib/autvid/catalog/catalog.json"
  }
}
