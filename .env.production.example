# Production/default-network defaults.
# Copy to .env.production, fill in wallet/network values, and run with:
# docker compose --env-file .env.production -f docker-compose.yml -f docker-compose.prod.yml up --build -d

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-root

ADMIN_DB=admindb
ADMIN_USER=admin
ADMIN_PASS=change-me-admin

# Absolute host-machine path to this repo. Leave "." when running docker compose
# directly from the host repo checkout.
HOST_WORKSPACE_DIR=.

DOMAIN=example.com

APP_HTTP_PORT=80
ADMIN_HTTP_PORT=8000
STREAM_HTTP_PORT=8081
ANTD_REST_PORT=8082
ANTD_GRPC_PORT=50051

# The PROD_* names avoid accidental overrides from devcontainer shell
# variables such as ANTD_NETWORK=local.
PROD_AUTONOMI_WALLET_KEY=0x<your_wallet_private_key>
PROD_ANTD_NETWORK=default
PROD_AUTONOMI_PEERS=

ANTD_PAYMENT_MODE=auto
ANTD_UPLOAD_VERIFY=true
ANTD_UPLOAD_RETRIES=3
ANTD_UPLOAD_TIMEOUT_SECONDS=120
ANTD_APPROVE_ON_STARTUP=true
HLS_SEGMENT_DURATION=1

ANTD_LOG_LEVEL=warn
ANTD_QUOTE_TIMEOUT_SECS=60
ANTD_STORE_TIMEOUT_SECS=120

CATALOG_ADDRESS=

# Local/custom EVM payment settings. Leave blank for standard network config.
PROD_EVM_RPC_URL=
PROD_EVM_PAYMENT_TOKEN_ADDRESS=
PROD_EVM_PAYMENT_VAULT_ADDRESS=
