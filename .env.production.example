# Production/default-network defaults.
# Copy to .env.production, fill in wallet/network values, and run with:
# docker compose --env-file .env.production -f docker-compose.yml -f docker-compose.prod.yml up --build -d

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-root

ADMIN_DB=admindb
ADMIN_USER=admin
ADMIN_PASS=change-me-admin

APP_ENV=production
ADMIN_USERNAME=autvid-admin
ADMIN_PASSWORD=change-me-uploader-password
ADMIN_AUTH_SECRET=change-me-long-random-token-signing-secret
ADMIN_AUTH_TTL_HOURS=12
ADMIN_REFRESH_TOKEN_TTL_HOURS=720
ADMIN_AUTH_COOKIE_SAME_SITE=Lax
# Keep true for HTTPS deployments so the HttpOnly admin cookie is Secure.
ADMIN_AUTH_COOKIE_SECURE=true
ADMIN_REQUEST_TIMEOUT_SECONDS=120
ADMIN_UPLOAD_REQUEST_TIMEOUT_SECONDS=3600

# Absolute host path for original uploads and transcoded segment files while
# jobs are processing or awaiting approval. Put this on a large, persistent disk.
# Compose fixes ownership for the non-root Rust admin service user on startup.
VIDEO_PROCESSING_HOST_PATH=/srv/autonomi-video-management/processing

DOMAIN=example.com

# Production should publish only the reverse proxy. Direct admin/stream ports
# can be added with an explicit debug override when needed.
APP_HTTP_PORT=80
CORS_ALLOWED_ORIGINS=https://example.com

# The PROD_* names avoid accidental overrides from devcontainer shell
# variables such as ANTD_NETWORK=local.
#
# Local/simple path: set PROD_AUTONOMI_WALLET_KEY directly.
# Preferred production path: leave PROD_AUTONOMI_WALLET_KEY blank, mount the key
# with an optional Compose secrets override, and set
# PROD_AUTONOMI_WALLET_KEY_FILE=/run/secrets/autonomi_wallet_key.
PROD_AUTONOMI_WALLET_KEY=0x<your_wallet_private_key>
# Optional Docker-secret/file alternative. This is an in-container path. When
# set, this file wins over PROD_AUTONOMI_WALLET_KEY inside the production antd
# gateway.
PROD_AUTONOMI_WALLET_KEY_FILE=
PROD_ANTD_NETWORK=default
# Optional Autonomi 2.0 bootstrap peers. Leave blank to use the gateway defaults.
# Plain host:port values are normalized to /ip4/<host>/udp/<port>/quic.
PROD_AUTONOMI_PEERS=
PROD_EVM_NETWORK=arbitrum-one

ANTD_PAYMENT_MODE=auto
ANTD_METADATA_PAYMENT_MODE=merkle
ANTD_UPLOAD_VERIFY=true
ANTD_UPLOAD_RETRIES=3
ANTD_UPLOAD_TIMEOUT_SECONDS=120
ANTD_QUOTE_CONCURRENCY=8
ANTD_UPLOAD_CONCURRENCY=4
ANTD_APPROVE_ON_STARTUP=true
ANTD_REQUIRE_COST_READY=false
ANTD_DIRECT_UPLOAD_MAX_BYTES=16777216
ADMIN_JOB_WORKERS=1
ADMIN_JOB_POLL_INTERVAL_SECONDS=2
ADMIN_JOB_LEASE_SECONDS=43200
ADMIN_JOB_MAX_ATTEMPTS=3
CATALOG_PUBLISH_JOB_MAX_ATTEMPTS=12
UPLOAD_MAX_FILE_BYTES=21474836480
UPLOAD_MAX_DURATION_SECONDS=14400
UPLOAD_MAX_SOURCE_PIXELS=33177600
UPLOAD_MAX_SOURCE_LONG_EDGE=7680
UPLOAD_MIN_FREE_BYTES=5368709120
UPLOAD_MAX_CONCURRENT_SAVES=2
UPLOAD_FFPROBE_TIMEOUT_SECONDS=30
HLS_SEGMENT_DURATION=1
FFMPEG_THREADS=2
FFMPEG_FILTER_THREADS=1
FFMPEG_MAX_PARALLEL_RENDITIONS=1
FINAL_QUOTE_APPROVAL_TTL_SECONDS=14400
APPROVAL_CLEANUP_INTERVAL_SECONDS=300

ANTD_LOG_LEVEL=warn
ANTD_REQUEST_TIMEOUT_SECONDS=60
ANTD_FILE_UPLOAD_REQUEST_TIMEOUT_SECONDS=3600
ANTD_JSON_BODY_LIMIT_BYTES=33554432
ANTD_QUOTE_TIMEOUT_SECS=60
ANTD_STORE_TIMEOUT_SECS=120

CATALOG_ADDRESS=

STREAM_CATALOG_CACHE_TTL_SECONDS=10
STREAM_MANIFEST_CACHE_TTL_SECONDS=300
# Keep the rust_stream container memory limit comfortably above this value;
# in-flight segment responses and runtime overhead also consume memory.
STREAM_SEGMENT_CACHE_TTL_SECONDS=3600
STREAM_SEGMENT_CACHE_MAX_BYTES=67108864
STREAM_REQUEST_TIMEOUT_SECONDS=60

# Optional monitoring/logging overlay settings. Keep these pinned so production
# observability redeploys do not drift unexpectedly.
PROMETHEUS_IMAGE=prom/prometheus:v2.55.1
PROMETHEUS_HTTP_PORT=9090
ALERTMANAGER_IMAGE=prom/alertmanager:v0.27.0
ALERTMANAGER_HTTP_PORT=9093
GRAFANA_IMAGE=grafana/grafana:11.3.0
GRAFANA_HTTP_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin-password
GRAFANA_AUTH_ANONYMOUS_ENABLED=false
LOKI_IMAGE=grafana/loki:2.9.8
LOKI_HTTP_PORT=3100
PROMTAIL_IMAGE=grafana/promtail:2.9.8
PROMTAIL_HTTP_PORT=9080

# Paste these into private Alertmanager config snippets or use them when
# rendering a host-local monitoring/alertmanager/alertmanager.yml.
ALERTMANAGER_SLACK_WEBHOOK_URL=
ALERTMANAGER_SMTP_SMARTHOST=
ALERTMANAGER_SMTP_FROM=
ALERTMANAGER_SMTP_USERNAME=
ALERTMANAGER_SMTP_PASSWORD=
ALERTMANAGER_EMAIL_TO=
ALERTMANAGER_PAGERDUTY_ROUTING_KEY=

# Local/custom EVM payment settings. Leave blank for standard network config.
PROD_EVM_RPC_URL=
PROD_EVM_PAYMENT_TOKEN_ADDRESS=
PROD_EVM_PAYMENT_VAULT_ADDRESS=
