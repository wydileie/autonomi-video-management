# Production/default-network defaults.
# Copy to .env.production, fill in wallet/network values, and run with:
# docker compose --env-file .env.production -f docker-compose.yml -f docker-compose.prod.yml up --build -d

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-root

ADMIN_DB=admindb
ADMIN_USER=admin
ADMIN_PASS=change-me-admin

APP_ENV=production
ADMIN_USERNAME=autvid-admin
ADMIN_PASSWORD=change-me-uploader-password
ADMIN_AUTH_SECRET=change-me-long-random-token-signing-secret
ADMIN_AUTH_TTL_HOURS=12

# Absolute host path for original uploads and transcoded segment files while
# jobs are processing or awaiting approval. Put this on a large, persistent disk.
# Compose fixes ownership for the non-root Rust admin service user on startup.
VIDEO_PROCESSING_HOST_PATH=/srv/autonomi-video-management/processing

DOMAIN=example.com

# Production should publish only the reverse proxy. Direct admin/stream ports
# can be added with an explicit debug override when needed.
APP_HTTP_PORT=80
CORS_ALLOWED_ORIGINS=https://example.com

# The PROD_* names avoid accidental overrides from devcontainer shell
# variables such as ANTD_NETWORK=local.
PROD_AUTONOMI_WALLET_KEY=0x<your_wallet_private_key>
PROD_ANTD_NETWORK=default
# Optional Autonomi 2.0 bootstrap peers. Leave blank to use the gateway defaults.
# Plain host:port values are normalized to /ip4/<host>/udp/<port>/quic.
PROD_AUTONOMI_PEERS=
PROD_EVM_NETWORK=arbitrum-one

ANTD_PAYMENT_MODE=auto
ANTD_METADATA_PAYMENT_MODE=merkle
ANTD_UPLOAD_VERIFY=true
ANTD_UPLOAD_RETRIES=3
ANTD_UPLOAD_TIMEOUT_SECONDS=120
ANTD_QUOTE_CONCURRENCY=8
ANTD_UPLOAD_CONCURRENCY=4
ANTD_APPROVE_ON_STARTUP=true
UPLOAD_MAX_FILE_BYTES=21474836480
UPLOAD_MAX_DURATION_SECONDS=14400
UPLOAD_MAX_SOURCE_PIXELS=33177600
UPLOAD_MAX_SOURCE_LONG_EDGE=7680
UPLOAD_MIN_FREE_BYTES=5368709120
UPLOAD_MAX_CONCURRENT_SAVES=2
UPLOAD_FFPROBE_TIMEOUT_SECONDS=30
HLS_SEGMENT_DURATION=1
FINAL_QUOTE_APPROVAL_TTL_SECONDS=14400
APPROVAL_CLEANUP_INTERVAL_SECONDS=300

ANTD_LOG_LEVEL=warn
ANTD_QUOTE_TIMEOUT_SECS=60
ANTD_STORE_TIMEOUT_SECS=120

CATALOG_ADDRESS=

STREAM_CATALOG_CACHE_TTL_SECONDS=10
STREAM_MANIFEST_CACHE_TTL_SECONDS=300
STREAM_SEGMENT_CACHE_TTL_SECONDS=60
STREAM_SEGMENT_CACHE_MAX_BYTES=67108864

# Local/custom EVM payment settings. Leave blank for standard network config.
PROD_EVM_RPC_URL=
PROD_EVM_PAYMENT_TOKEN_ADDRESS=
PROD_EVM_PAYMENT_VAULT_ADDRESS=
