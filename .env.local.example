# Local self-contained testnet defaults.
# Copy to .env.local and run with:
# docker compose --env-file .env.local -f docker-compose.yml -f docker-compose.local.yml up --build

POSTGRES_USER=postgres
POSTGRES_PASSWORD=RootPassword

ADMIN_DB=admindb
ADMIN_USER=admin
ADMIN_PASS=AdminSecurePass

APP_ENV=development
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_AUTH_SECRET=dev-only-change-this-token-secret
ADMIN_AUTH_TTL_HOURS=12

# Host path for original uploads and transcoded segment files while jobs are
# processing or awaiting approval. For large test files, point this at a disk
# with plenty of free space. If Docker runs on the host while this command is
# launched inside a devcontainer, use an absolute host-machine path.
# Compose fixes ownership for the non-root Python admin container on startup.
VIDEO_PROCESSING_HOST_PATH=./.autvid/video_processing

DOMAIN=localhost

APP_HTTP_PORT=80

# Direct admin/stream ports are only used when adding
# docker-compose.debug-ports.yml for local debugging.
ADMIN_HTTP_PORT=8000
STREAM_HTTP_PORT=8081
RUST_ADMIN_HTTP_PORT=8002
ANTD_REST_PORT=8082
ANTD_GRPC_PORT=50051
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173

ANTD_PAYMENT_MODE=auto
ANTD_METADATA_PAYMENT_MODE=merkle
ANTD_UPLOAD_VERIFY=true
ANTD_UPLOAD_RETRIES=3
ANTD_UPLOAD_TIMEOUT_SECONDS=120
ANTD_QUOTE_CONCURRENCY=8
ANTD_UPLOAD_CONCURRENCY=4
ANTD_APPROVE_ON_STARTUP=false
RUST_ADMIN_APPROVE_ON_STARTUP=false
UPLOAD_MAX_FILE_BYTES=21474836480
UPLOAD_MAX_DURATION_SECONDS=14400
UPLOAD_MAX_SOURCE_PIXELS=33177600
UPLOAD_MAX_SOURCE_LONG_EDGE=7680
UPLOAD_MIN_FREE_BYTES=5368709120
UPLOAD_MAX_CONCURRENT_SAVES=2
UPLOAD_FFPROBE_TIMEOUT_SECONDS=30
HLS_SEGMENT_DURATION=1
FFMPEG_THREADS=2
FFMPEG_FILTER_THREADS=1
FINAL_QUOTE_APPROVAL_TTL_SECONDS=14400
APPROVAL_CLEANUP_INTERVAL_SECONDS=300

ANT_DEVNET_PRESET=default
ANTD_LOG_LEVEL=warn
ANTD_QUOTE_TIMEOUT_SECS=60
ANTD_STORE_TIMEOUT_SECS=120

CATALOG_ADDRESS=

STREAM_CATALOG_CACHE_TTL_SECONDS=10
STREAM_MANIFEST_CACHE_TTL_SECONDS=300
STREAM_SEGMENT_CACHE_TTL_SECONDS=60
STREAM_SEGMENT_CACHE_MAX_BYTES=67108864
