# Postgres root credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=RootPassword

# Python Admin DB
ADMIN_DB=admindb
ADMIN_USER=admin
ADMIN_PASS=AdminSecurePass

# Single uploader/admin login for upload and library management.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisUploaderPassword
ADMIN_AUTH_SECRET=ChangeThisLongRandomTokenSigningSecret
ADMIN_AUTH_TTL_HOURS=12

# Absolute host-machine path to this repo.
# Required when running docker compose from inside the devcontainer because the
# Docker daemon resolves bind mounts on the host, not inside /workspaces.
# Leave as "." when running docker compose directly from the host repo checkout.
HOST_WORKSPACE_DIR=.

# Host path for original uploads and transcoded segment files while jobs are
# processing or awaiting approval. Put this on a large, persistent disk.
# Use an absolute host path for production or when Docker runs outside this repo.
VIDEO_PROCESSING_HOST_PATH=./.autvid/video_processing

# Domain label used by external proxies or deployment tooling.
DOMAIN=va.worldwidenodes.cyou

# Host-published ports. Change these if another local stack already owns them.
APP_HTTP_PORT=80
ADMIN_HTTP_PORT=8000
STREAM_HTTP_PORT=8081
ANTD_REST_PORT=8082
ANTD_GRPC_PORT=50051

# ── Production/default-network antd daemon ───────────────────────────────────
# The PROD_* names avoid accidental overrides from devcontainer shell variables
# such as ANTD_NETWORK=local.
PROD_AUTONOMI_WALLET_KEY=0x<your_wallet_private_key>
PROD_ANTD_NETWORK=default
PROD_AUTONOMI_PEERS=

# Local self-contained devnet preset: minimal, small, or default.
ANT_DEVNET_PRESET=default

# Autonomi SDK payment strategy for segment uploads:
# "auto" chooses merkle batch payments for 64+ chunks and single payments otherwise.
# Use "merkle" for larger uploads or "single" for small/debug uploads.
ANTD_PAYMENT_MODE=auto

# Verify each uploaded segment can be fetched back before marking a video ready.
# This catches local-devnet storage issues early instead of publishing bad addresses.
ANTD_UPLOAD_VERIFY=true
ANTD_UPLOAD_RETRIES=3
ANTD_UPLOAD_TIMEOUT_SECONDS=120

# Server-side upload admission limits. Defaults allow up to a 20 GiB, 4-hour,
# 8K-source video while keeping 5 GiB of processing-disk headroom.
UPLOAD_MAX_FILE_BYTES=21474836480
UPLOAD_MAX_DURATION_SECONDS=14400
UPLOAD_MAX_SOURCE_PIXELS=33177600
UPLOAD_MAX_SOURCE_LONG_EDGE=7680
UPLOAD_MIN_FREE_BYTES=5368709120
UPLOAD_MAX_CONCURRENT_SAVES=2
UPLOAD_FFPROBE_TIMEOUT_SECONDS=30

# Seconds per HLS .ts chunk. Shorter forced-keyframe chunks are more reliable on
# local devnets because each Autonomi object stays smaller.
HLS_SEGMENT_DURATION=1

# Cap FFmpeg/x264 worker threads to keep high-resolution portrait transcodes
# from exhausting container memory on high-core hosts. Raise for faster encodes
# if the Docker host has enough RAM.
FFMPEG_THREADS=2
FFMPEG_FILTER_THREADS=1

# Seconds an awaiting-approval final quote remains valid before local transcoded
# files are deleted. Default is 4 hours.
FINAL_QUOTE_APPROVAL_TTL_SECONDS=14400
APPROVAL_CLEANUP_INTERVAL_SECONDS=300

# Approve the configured wallet to spend storage tokens when python_admin starts.
# This is required once per wallet/payment contract before write operations.
ANTD_APPROVE_ON_STARTUP=true

# Optional bootstrap address for a previously published network-hosted video catalog.
# When empty, the app starts with an empty catalog and writes the latest catalog
# address into the shared catalog_state volume.
CATALOG_ADDRESS=

# Rust stream in-process cache settings. Set any TTL or byte cap to 0 to disable.
STREAM_CATALOG_CACHE_TTL_SECONDS=10
STREAM_MANIFEST_CACHE_TTL_SECONDS=300
STREAM_SEGMENT_CACHE_TTL_SECONDS=60
STREAM_SEGMENT_CACHE_MAX_BYTES=67108864

# EVM configuration for custom production networks. Leave blank for standard
# network defaults.
PROD_EVM_RPC_URL=
PROD_EVM_PAYMENT_TOKEN_ADDRESS=
PROD_EVM_PAYMENT_VAULT_ADDRESS=
