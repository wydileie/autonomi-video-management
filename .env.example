# Postgres root credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=RootPassword

# Python Admin DB
ADMIN_DB=admindb
ADMIN_USER=admin
ADMIN_PASS=AdminSecurePass

# TLS / domain
DOMAIN=va.worldwidenodes.cyou

# ── Autonomi / antd daemon ────────────────────────────────────────────────────
# Hex-encoded EVM wallet private key used by antd to pay for storage
# Generate with: openssl rand -hex 32  (prefix with 0x)
AUTONOMI_WALLET_KEY=0x<your_wallet_private_key>

# Autonomi network mode: "default" (mainnet) or "local" (devnet)
ANTD_NETWORK=default

# Autonomi SDK payment strategy for segment uploads:
# "auto" chooses merkle batch payments for 64+ chunks and single payments otherwise.
# Use "merkle" for larger uploads or "single" for small/debug uploads.
ANTD_PAYMENT_MODE=auto

# Approve the configured wallet to spend storage tokens when python_admin starts.
# This is required once per wallet/payment contract before write operations.
ANTD_APPROVE_ON_STARTUP=true

# Optional bootstrap address for a previously published network-hosted video catalog.
# When empty, the app starts with an empty catalog and writes the latest catalog
# address into the shared catalog_state volume.
CATALOG_ADDRESS=

# Bootstrap peer multiaddrs for the Autonomi network (comma-separated).
# Leave empty to use built-in default bootstrap peers for mainnet.
# Example: /ip4/1.2.3.4/tcp/12000/p2p/12D3Koo...
AUTONOMI_PEERS=

# EVM configuration (only needed for local devnet or custom networks)
# For mainnet Arbitrum One these are provided by the antd binary defaults.
EVM_RPC_URL=
EVM_PAYMENT_TOKEN_ADDRESS=
EVM_PAYMENT_VAULT_ADDRESS=
